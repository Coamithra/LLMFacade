# Copy to .env and fill in. Used by tests/integration/.
# .env is gitignored; .env.example is the template.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Ollama integration tests talk to a local server. Override the host if
# yours isn't on the default http://localhost:11434.
# OLLAMA_HOST=http://localhost:11434

# Override the chat model used for the Ollama integration test. Defaults to
# qwen3.5:4b — small enough to pull quickly, large enough that tool calling
# is reliable. Smaller models (e.g. llama3.2:1b) often fail to emit a
# tool_call at all and cause spurious test failures.
# OLLAMA_TEST_MODEL=qwen3.5:4b
