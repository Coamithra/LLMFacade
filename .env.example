# Copy to .env and fill in. Used by tests/integration/.
# .env is gitignored; .env.example is the template.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# llama-server integration tests talk to a local llama.cpp server. Override
# the host if yours isn't on the default http://localhost:8080. The provider
# constructor expects the OpenAI-compat root (.../v1); the integration
# fixture appends /v1 automatically when the host omits it.
# LLAMACPP_HOST=http://localhost:8080

# Override the chat model used for the llamacpp integration test. The id
# must match what llama-server reports (typically the GGUF basename or
# whatever you set via --alias / llama-swap config).
# LLAMACPP_MODEL=qwen2.5-3b-instruct-q4_k_m
